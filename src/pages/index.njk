              <h3>Rechtskunde / Organisation im Rettungsdienst</h3>
            </div>
          </div>
        </div>
      </div>
    </section>
    <section id="contact" class="contact">
      <div class="container">
        <div class="section-title">
          <h2>Kontakt</h2>
        </div>
        <div class="row">
          <div class="col-lg-4 col-md-6">
